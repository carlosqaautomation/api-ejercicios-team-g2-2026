{
  "loginRequest": {
    "email": "#(user)",
    "password": "#(password)"
  },
  "createAccountRequest": {
    "accountType": "#(accountType)",
    "currency": "#(currency)",
    "initialBalance": "#(parseInt(initialBalance))"
  },
  "createCardRequest": {
    "accountId": "#(idAccount)",
    "cardType": "#(cardType)",
    "cardHolderName": "#(cardHolderName)"
  },
  "pagarServicioRequest": {
    "accountId": "#(accountId)",
    "serviceId": "#(serviceId)",
    "amount": "#(amount)",
    "reference": "#(reference)"
  }
}
